{
  "name": "@ai-job-hunter/worker",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "predev": "pnpm --filter @ai-job-hunter/scoring build",
    "prescrape:startupjobs": "pnpm --filter @ai-job-hunter/scoring build",
    "prescrape:jobs": "pnpm --filter @ai-job-hunter/scoring build",
    "prescore:jobs": "pnpm --filter @ai-job-hunter/scoring build",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "playwright:install": "playwright install chromium",
    "scrape:startupjobs": "tsx src/index.ts scrape:startupjobs",
    "scrape:jobs": "tsx src/index.ts scrape:jobs",
    "scrape:mock": "tsx src/index.ts scrape:mock",
    "score:jobs": "tsx src/index.ts score:jobs",
    "assist:application": "tsx src/index.ts assist:application"
  },
  "dependencies": {
    "@ai-job-hunter/scoring": "workspace:*",
    "@ai-job-hunter/shared": "workspace:*",
    "dotenv": "^16.5.0",
    "mongoose": "^9.7.2",
    "playwright": "^1.52.0"
  },
  "devDependencies": {
    "tsx": "^4.19.4"
  }
}
